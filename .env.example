# ============================================================
# Orchestrator 环境配置
# 使用方式：复制为 .env，按需修改，运行 .\deploy.ps1
# ============================================================

# ── LLM 主机地址 ──────────────────────────────────────────
# 本机运行 llama.cpp（默认）：
LLM_HOST=host.docker.internal

# 局域网其他机器运行 llama.cpp：
# LLM_HOST=192.168.1.100

# ── LLM 端口 ──────────────────────────────────────────────
# 对应 llm-scripts/ 里各启动脚本的 --port 参数
LLM_PORT=8081

# ── 模型名称 ──────────────────────────────────────────────
# 对应 llama.cpp 启动脚本里的 --alias 参数
#
# 可选模型（见 ~/llm-scripts/）：
#   qwen3.6-27b          代码模式，复杂任务首选（start-27b-ImageInputUnsupported.sh）
#   qwen3.6-27b-vision   27B 多模态（start-27b-ImageInputSupported.sh）
#   qwen3.6-35b          35B 代码模式，日常最快（start-35b-ImageInputUnsupported.sh）
#   qwen3.6-35b-vision   35B 多模态（start-35b-ImageInputSupported.sh）
#   qwen3.6-uncensored   35B Uncensored（start-uncensored.sh）
LLM_MODEL=qwen3.6-27b

# ── 项目根目录 ────────────────────────────────────────────
# 整个 PersonalProjects 目录挂载到容器 /projects
# 启动时用 --project /projects/<子目录> 指定具体项目
# 默认值已内置，通常不需要改
# PROJECTS_ROOT=C:/Users/Peng/Desktop/PersonalProjects
